{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "clavis",
  "version": "0.1.0",
  "identifier": "com.achyllisss.clavis",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "clavis",
        "width": 640,
        "height": 480,
        "decorations": false,
        "resizable": false,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "licenseFile": "assets/installer/EULA.txt",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both",
        "headerImage": "assets/installer/installer-header.bmp",
        "sidebarImage": "assets/installer/installer-sidebar.bmp",
        "installerIcon": "assets/installer/installer.ico"
      }
    },
    "macOS": {
      "dmg": {
        "background": "assets/installer/dmg-background.png"
      }
    }
  }
}
