{
  "manifest_version": 3,
  "name": "Clavis Browser Companion",
  "version": "0.1.0",
  "description": "Companion browser extension for the Clavis desktop password manager.",
  "permissions": [
    "activeTab",
    "nativeMessaging"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html"
  },
  "key": ""
}
